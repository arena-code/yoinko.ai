{
  "name": "yoinko",
  "version": "0.6.0",
  "type": "module",
  "description": "yoınko.ai — fewer buttons. more yoınking.",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "concurrently --names \"server,watch\" --prefix-colors \"cyan,magenta\" \"tsx watch --env-file=.env src/server/index.ts\" \"node scripts/watch-client.js\"",
    "start": "node dist/server/index.js",
    "build": "npm run build:server && npm run build:client && npm run build:editor",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "node scripts/build-client.js",
    "build:client:sourcemaps": "SOURCEMAP=true NODE_ENV=production node scripts/build-client.js",
    "build:editor": "node scripts/build-editor.js",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.client.json",
    "glitchtip:sourcemaps:inject": "glitchtip-cli sourcemaps inject ./public/js && glitchtip-cli sourcemaps inject ./dist",
    "glitchtip:sourcemaps:upload": "glitchtip-cli sourcemaps upload ./public/js --org \"$GLITCHTIP_ORG\" --project \"$GLITCHTIP_PROJECT\" && glitchtip-cli sourcemaps upload ./dist --org \"$GLITCHTIP_ORG\" --project \"$GLITCHTIP_PROJECT\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.0",
    "@sentry/node": "^10.53.1",
    "@sentry/react": "^10.53.1",
    "@tiptap/core": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-table-cell": "^3.22.4",
    "@tiptap/extension-table-header": "^3.22.4",
    "@tiptap/extension-table-row": "^3.22.4",
    "@tiptap/extension-task-item": "^3.22.4",
    "@tiptap/extension-task-list": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@xyflow/react": "^12.10.2",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "esbuild": "^0.28.0",
    "express": "^4.21.2",
    "jose": "^6.2.3",
    "jspreadsheet-ce": "^5.0.4",
    "multer": "^1.4.5-lts.2",
    "openai": "^4.91.1",
    "posthog-node": "^5.34.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-kanban-kit": "^0.0.2-beta.7",
    "uuid": "^11.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
